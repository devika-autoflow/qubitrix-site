# ---- Client-side (safe to expose, prefixed VITE_) ----
# n8n webhook that receives contact-form + request-builder submissions (JSON POST).
# The n8n workflow is responsible for emailing info@ and/or storing the lead (e.g. in Supabase).
VITE_N8N_WEBHOOK_URL=

# n8n webhook that powers the chat console (JSON POST, returns { reply })
VITE_CHAT_WEBHOOK_URL=

# Calendly booking link, e.g. https://calendly.com/yourname/30min
VITE_CALENDLY_URL=

# ---- Supabase auth (anon key is public by design; still never commit real values) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Supabase (server-side integrations) ----
SUPABASE_URL=
SUPABASE_REST_URL=
SUPABASE_ANON_KEY=

# ---- Server-side ONLY (set in Netlify UI → Site settings → Environment variables) ----
# NEVER commit real keys. NEVER prefix these with VITE_.
# Chat provider: set ONE of these. Anthropic is preferred.
ANTHROPIC_API_KEY=
# CHAT_MODEL=claude-haiku-4-5

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
